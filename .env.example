NODE_ENV=development
PORT=3000
GPT_IMAGE2_UI_MODE=configurable

SITE_ACCESS_PASSWORD=
GPT_IMAGE2_API_KEY=
GPT_IMAGE2_API_BASE_URL=https://api.vbcode.io/v1
GPT_IMAGE2_DEFAULT_ENDPOINT=
GPT_IMAGE2_GENERATION_ENDPOINT=
GPT_IMAGE2_EDIT_ENDPOINT=
GPT_IMAGE2_DEFAULT_MODEL=gpt-image-2
GPT_IMAGE2_AUTH_HEADER=Authorization
GPT_IMAGE2_AUTH_SCHEME=
REQUEST_TIMEOUT_MS=120000
MAX_UPLOAD_BYTES=10485760
MAX_UPLOAD_COUNT=4
MAX_TOTAL_UPLOAD_BYTES=41943040
ALLOWED_IMAGE_MIME_TYPES=image/png,image/jpeg,image/webp
ALLOW_PRIVATE_ENDPOINTS=false
IMAGE_JOB_DB_PATH=/app/data/image-jobs.sqlite
IMAGE_JOB_CONCURRENCY=1
IMAGE_JOB_MAX_PENDING=20
IMAGE_JOB_RESULT_TTL_MS=86400000
IMAGE_JOB_POLL_RETRY_MS=2000

# Paid mode / accounts
# docker-compose keeps the root configurable service using BILLING_ENABLED below.
# The sealed service can override billing with SEALED_BILLING_ENABLED=true and SEALED_APP_BASE_URL=https://your-domain/sealed.
BILLING_ENABLED=false
SEALED_BILLING_ENABLED=false
APP_DB_PATH=/app/data/app.sqlite
APP_BASE_URL=http://localhost:3000
SEALED_APP_BASE_URL=http://localhost:3001
SESSION_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
SESSION_TTL_DAYS=30
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-this-password
ALLOW_SELF_REGISTRATION=false
INITIAL_FREE_CREDITS=0
CREDIT_COST_GENERATE=1
CREDIT_COST_REFERENCE=1
CREDIT_COST_EDIT=1

# Alipay payment packs and credentials
PAYMENT_PROVIDER=alipay
PAYMENT_CURRENCY=CNY
PAYMENT_PACKS_JSON=[{"id":"starter","credits":100,"amountCents":990,"currency":"CNY","title":"入门包"}]
# Optional static QR code for manual payment. Users scan it, then an admin manually adds credits.
MANUAL_PAYMENT_QR_URL=
MANUAL_PAYMENT_TITLE=扫码付款后联系管理员加额度
MANUAL_PAYMENT_DESCRIPTION=请备注注册邮箱或订单信息，管理员确认到账后会手动为你的账户添加额度。
# WeChat can be added behind the same payment module later; current implementation enables Alipay only.
ALIPAY_APP_ID=
ALIPAY_SELLER_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
